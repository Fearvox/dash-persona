{
  "appId": "design.zonic.dash-collector",
  "productName": "DASH Collector",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "ui/**",
    "package.json"
  ],
  "mac": {
    "category": "public.app-category.productivity",
    "target": ["dmg", "zip"],
    "identity": null,
    "hardenedRuntime": false,
    "gatekeeperAssess": false
  },
  "dmg": {
    "contents": [
      { "x": 130, "y": 220 },
      { "x": 410, "y": 220, "type": "link", "path": "/Applications" },
      { "x": 270, "y": 340, "type": "file", "path": "scripts/install-mac.sh" }
    ],
    "window": { "width": 540, "height": 400 }
  },
  "afterPack": "./afterPack.js",
  "win": {
    "target": ["nsis"]
  },
  "extraMetadata": {
    "main": "dist/main.js"
  }
}
