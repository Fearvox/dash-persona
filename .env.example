# DashPersona Configuration
# See https://github.com/Fearvox/dash-persona for documentation

# Optional: Default timezone offset for growth baseline (hours from UTC, default: 8 for CST)
# TIMEZONE_OFFSET=8

# Optional: Enable experimental HTML parsing adapter
# ENABLE_HTML_ADAPTER=true

# Optional: Custom platform benchmark data URL
# BENCHMARK_DATA_URL=

# Optional: Analytics (Vercel)
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=
